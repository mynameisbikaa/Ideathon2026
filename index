<!-- NAV -->
<nav>
  <div class="nav-logo">Таза<span>Жер</span></div>
  <div class="nav-links">
    <a href="#problem">Проблема</a>
    <a href="#demo">Демо</a>
    <a href="#map-section">Карта</a>
    <a href="#chain">EcoChain</a>
