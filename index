        <div class="stat-num">2027</div>
        <div class="stat-label" data-ru="запрет пластиковых пакетов" data-kg="пластик баштыкчаларга тыюу">запрет пластиковых пакетов</div>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEM -->
<section class="problems" id="problem">
  <div class="section-label" data-ru="Проблема" data-kg="Маселе">Проблема</div>
  <h2 class="section-title" data-ru="Мусорят все — от детей до аксакалов" data-kg="Баары таштандылайт — балдардан аксакалдарга чейин">Мусорят все — от детей до аксакалов</h2>
