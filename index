  { lat: 40.93, lng: 73.00, name: 'Жалал-Абад', type: 'medium', ru: 'Стекло + пластик, ~0.6 тонны', kg: 'Айнек + пластик, ~0.6 тонна' },
  { lat: 41.42, lng: 75.99, name: 'Нарын', type: 'medium', ru: 'Горный маршрут, ~0.4 тонны', kg: 'Тоо жолу, ~0.4 тонна' },
  { lat: 42.72, lng: 74.24, name: 'Кара-Балта', type: 'clean', ru: 'Очищено 3 дня назад', kg: '3 күн мурун тазаланды' },
  { lat: 42.18, lng: 76.07, name: 'Балыкчы', type: 'medium', ru: 'Рыболовные сети + пластик', kg: 'Балык торлору + пластик' },
];

const colors = { high: '#c0392b', medium: '#e8a020', clean: '#1a6b3c' };

hotspots.forEach(h => {
  const marker = L.circleMarker([h.lat, h.lng], {
    radius: h.type === 'high' ? 14 : h.type === 'medium' ? 10 : 8,
    fillColor: colors[h.type], color: '#fff', weight: 2,
    opacity: 1, fillOpacity: 0.85
  }).addTo(map);
  marker.bindPopup(`<strong>${h.name}</strong><br/>${h.ru}<br/><small style="color:#1a6b3c;">Таза Жер EcoChain</small>`);
});

// ─── REVEAL ON SCROLL ─────────────────────────────────────────
const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.15 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>
