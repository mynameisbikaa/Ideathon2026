<script>
// ─── LANGUAGE ───────────────────────────────────────────────
let currentLang = 'ru';
function setLang(lang) {
  currentLang = lang;
  document.querySelectorAll('[data-ru]').forEach(el => {
    el.textContent = el.getAttribute('data-' + lang) || el.getAttribute('data-ru');
  });
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('active'));
  document.querySelector('.lang-btn[onclick="setLang(\'' + lang + '\')"]').classList.add('active');
}

// ─── WASTE DATA ──────────────────────────────────────────────
const wasteData = [
  { ru: 'Пластик ПЭТ', kg: 'ПЭТ пластик', conf: 91, priority: { ru: 'Высокий 🔴', kg: 'Жогорку 🔴' }, volume: '~8–12 кг', reward: 220 },
  { ru: 'Пластиковые пакеты', kg: 'Пластик баштыкчалар', conf: 87, priority: { ru: 'Высокий 🔴', kg: 'Жогорку 🔴' }, volume: '~3–5 кг', reward: 180 },
  { ru: 'Стеклянные бутылки', kg: 'Айнек бөтөлкөлөр', conf: 94, priority: { ru: 'Средний 🟡', kg: 'Орточо 🟡' }, volume: '~5–7 кг', reward: 150 },
  { ru: 'Органические отходы', kg: 'Органикалык калдыктар', conf: 78, priority: { ru: 'Низкий 🟢', kg: 'Төмөнкү 🟢' }, volume: '~10–15 кг', reward: 90 },
  { ru: 'Металлические банки', kg: 'Металл банкалар', conf: 89, priority: { ru: 'Средний 🟡', kg: 'Орточо 🟡' }, volume: '~2–4 кг', reward: 200 },
  { ru: 'Смешанный мусор', kg: 'Аралаш таштанды', conf: 82, priority: { ru: 'Высокий 🔴', kg: 'Жогорку 🔴' }, volume: '~15–20 кг', reward: 260 },
];

// ─── AI DEMO ─────────────────────────────────────────────────
const fileInput = document.getElementById('file-input');
const previewImg = document.getElementById('preview-img');
const uploadZone = document.getElementById('upload-zone');
const aiAnalyzing = document.getElementById('ai-analyzing');
const aiResult = document.getElementById('ai-result');
const aiBar = document.getElementById('ai-bar');
const aiStatusText = document.getElementById('ai-status-text');

const statusMessages = {
  ru: ['Инициализация модели...', 'Загрузка весов YOLOv8...', 'Препроцессинг изображения...', 'Детекция объектов...', 'Классификация отходов...', 'Расчёт вознаграждения...'],
  kg: ['Модель баштоо...', 'YOLOv8 салмактарын жүктөө...', 'Сүрөттү иштетүү...', 'Объектилерди аныктоо...', 'Калдыктарды классификациялоо...', 'Сыйлык эсептөө...']
};

fileInput.addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    previewImg.src = ev.target.result;
    previewImg.style.display = 'block';
    uploadZone.style.display = 'none';
    aiResult.style.display = 'none';
    runAI();
  };
  reader.readAsDataURL(file);
});

function runAI() {
  aiAnalyzing.style.display = 'block';
  aiBar.style.width = '0%';
  const msgs = statusMessages[currentLang] || statusMessages.ru;
  let progress = 0;
  let msgIdx = 0;
  aiStatusText.textContent = msgs[0];

  const interval = setInterval(() => {
    progress += Math.random() * 4 + 2;
    if (progress > 100) progress = 100;
    aiBar.style.width = progress + '%';
    const newIdx = Math.floor(progress / (100 / msgs.length));
    if (newIdx !== msgIdx && newIdx < msgs.length) {
      msgIdx = newIdx;
      aiStatusText.textContent = msgs[msgIdx];
    }
    if (progress >= 100) {
      clearInterval(interval);
      setTimeout(showResult, 300);
    }
  }, 80);
}

function showResult() {
  aiAnalyzing.style.display = 'none';
  const pick = wasteData[Math.floor(Math.random() * wasteData.length)];

  document.getElementById('waste-type').textContent = currentLang === 'kg' ? pick.kg : pick.ru;
  document.getElementById('confidence-val').textContent = pick.conf + '%';
  document.getElementById('confidence-bar').style.width = pick.conf + '%';
  document.getElementById('priority-val').textContent = currentLang === 'kg' ? pick.priority.kg : pick.priority.ru;
  document.getElementById('volume-val').textContent = pick.volume;
  document.getElementById('reward-amount').textContent = '+' + pick.reward + ' сом';

  aiResult.style.display = 'block';
  aiResult.style.opacity = '0';
  aiResult.style.transform = 'translateY(10px)';
  aiResult.style.transition = 'opacity 0.4s, transform 0.4s';
  requestAnimationFrame(() => {
    aiResult.style.opacity = '1';
    aiResult.style.transform = 'translateY(0)';
  });
}

