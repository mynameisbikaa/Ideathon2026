  <div style="display:flex;align-items:center;gap:1rem;">
    <div class="lang-toggle">
      <button class="lang-btn active" onclick="setLang('ru')">RU</button>
      <button class="lang-btn" onclick="setLang('kg')">KY</button>
    </div>
    <button class="nav-cta" onclick="document.getElementById('demo').scrollIntoView({behavior:'smooth'})">
      <span data-ru="Попробовать" data-kg="Байкап көр">Попробовать</span>
    </button>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <div class="hero-label">
      <span class="dot"></span>
      <span data-ru="MVP · Апрель 2026 · Кыргызстан" data-kg="MVP · Апрель 2026 · Кыргызстан">MVP · Апрель 2026 · Кыргызстан</span>
    </div>
    <h1 class="hero-title">
      <span class="accent" data-ru="Таза Жер" data-kg="Таза Жер">Таза Жер</span><br/>
